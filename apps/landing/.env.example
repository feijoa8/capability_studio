# Supabase (same project as Capability Studio — Edge Functions + auth cookies)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Main Vite app origin (redirects: /app, /auth/signup, /auth/login → app root by default)
NEXT_PUBLIC_APP_URL=http://localhost:5173

# Optional: override sign-in / sign-up URLs if your SPA uses dedicated paths
# NEXT_PUBLIC_APP_LOGIN_URL=http://localhost:5173/
# NEXT_PUBLIC_APP_SIGNUP_URL=http://localhost:5173/
# NEXT_PUBLIC_AUTH_LOGIN_PATH=/
# NEXT_PUBLIC_AUTH_SIGNUP_PATH=/

# Canonical public URL for this Next site (metadata / Open Graph)
NEXT_PUBLIC_SITE_URL=http://localhost:3001
